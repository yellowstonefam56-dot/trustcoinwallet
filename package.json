{
  "name": "trustcoinwallet",
  "version": "1.0.0",
  "description": "Full-stack cryptocurrency wallet application",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "client:install": "cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "mongoose": "^7.6.3",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.0",
    "web3": "^1.10.3",
    "@walletconnect/client": "^1.8.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1"
  }
}
